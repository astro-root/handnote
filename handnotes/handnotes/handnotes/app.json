{
  "expo": {
    "name": "HandNotes",
    "slug": "handnotes",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d1a"
    },
    "platforms": ["ios", "android", "web"],
    "web": { "bundler": "metro" },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.handnotes.app" },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d1a"
      },
      "package": "com.handnotes.app"
    }
  }
}
